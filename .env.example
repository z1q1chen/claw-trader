# === Required ===

# Polygon RPC endpoint (get free from https://chainstack.com/)
CHAINSTACK_NODE=https://polygon-mainnet.core.chainstack.com/YOUR_KEY

# EVM wallet private key (hex format, no 0x prefix)
# WARNING: Use a dedicated trading wallet with limited funds
POLYCLAW_PRIVATE_KEY=

# LLM API key for hedge analysis (OpenRouter: https://openrouter.ai/)
# Not required if using a local model for all LLM tasks
OPENROUTER_API_KEY=

# === Trading Parameters ===

# Maximum USD per single position (default: 50)
TRADE_MAX_POSITION=50

# Minimum perceived edge percentage to trigger a trade (default: 5)
TRADE_MIN_EDGE=5

# Market scan interval in minutes (default: 30)
SCAN_INTERVAL_MINUTES=30

# === Notifications (optional) ===

# Channel type for trade notifications: slack, telegram, discord, etc.
ANNOUNCE_CHANNEL=

# Channel/chat ID for notifications
ANNOUNCE_TARGET=

# === Local Model (optional) ===

# Set to "true" to use a local LLM instead of OpenRouter for hedge analysis
USE_LOCAL_MODEL=false

# Local model server URL (only used if USE_LOCAL_MODEL=true)
LOCAL_MODEL_URL=http://127.0.0.1:1234/v1

# Local model name as reported by your server's /v1/models endpoint
LOCAL_MODEL_NAME=
