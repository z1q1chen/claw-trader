# Claw Trader Configuration
# All variables prefixed with CT_

# App
CT_DEBUG=false
CT_LOG_FORMAT=text  # text or json

# Authentication
CT_AUTH_ENABLED=false
CT_API_SECRET_KEY=  # Set to enable API key auth

# Dry-run mode (enabled by default for safety)
CT_DRY_RUN_MODE=true

# LLM Configuration
CT_DEFAULT_LLM_PROVIDER=gemini
CT_GEMINI_API_KEY=
CT_OPENAI_API_KEY=
CT_ANTHROPIC_API_KEY=

# IBKR Configuration
CT_IBKR_HOST=127.0.0.1
CT_IBKR_PORT=7497
CT_IBKR_CLIENT_ID=1

# Polymarket Configuration
CT_POLYMARKET_PRIVATE_KEY=
CT_POLYMARKET_API_KEY=
CT_POLYGON_RPC_URL=
CT_POLYMARKET_CONDITION_IDS=[]  # JSON array of condition IDs

# Risk Limits
CT_MAX_POSITION_USD=10000.0
CT_MAX_DAILY_LOSS_USD=5000.0
CT_MAX_PORTFOLIO_EXPOSURE_USD=50000.0
CT_MAX_SINGLE_TRADE_USD=2000.0
CT_MAX_DRAWDOWN_PCT=10.0
CT_MAX_POSITION_CONCENTRATION_PCT=20.0

# Signal Engine
CT_SIGNAL_SCAN_INTERVAL_MS=500
CT_SIGNAL_COOLDOWN_S=60.0
CT_PRICE_FEED_SYMBOLS=["AAPL","MSFT","GOOGL","AMZN","SPY"]

# LLM Call Interval
CT_LLM_MIN_CALL_INTERVAL_S=2.0

# Portfolio Sync
CT_PORTFOLIO_SYNC_INTERVAL_S=30.0

# Rate Limiting
CT_RATE_LIMIT_RPM=120

# CORS
CT_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Database
CT_DATABASE_URL=sqlite+aiosqlite:///claw_trader.db
